@startuml 05-despliegue-mvp

title Diagrama de Despliegue — MVP actual (presupuesto $0)
header Estado HOY: monolito modular, un solo proceso (Proyecto.md §8.2)

!theme plain
skinparam defaultFontName Consolas
skinparam wrapWidth 220
skinparam node {
  BackgroundColor LightYellow
  BorderColor Orange
}
skinparam database {
  BackgroundColor LightBlue
  BorderColor Blue
}
skinparam component {
  BackgroundColor LightGray
  BorderColor Black
}
skinparam cloud {
  BackgroundColor White
  BorderColor Gray
}
skinparam note {
  BackgroundColor LightYellow
  BorderColor Orange
}

actor "Jugador" as Jugador

cloud "Vercel / Render Static\n(Gratis)" as Frontend {
  component "Cliente React + Vite" as Client
}

node "Render Web Service\n(plan Free — 1 instancia)" as RenderWeb {
  component "server/index.js\n(punto de entrada único)" as Entry
  component "auth/" as Auth
  component "rooms/" as Rooms
  component "game/*" as Game
  component "state/" as State
  component "timer/master.js" as Timer
  component "chat/" as Chat
  component "bot/" as Bot
  component "observability/" as Obs
  component "events/" as Events
  component "config/" as Config

  Entry --> Config
  Entry --> Auth
  Entry --> Rooms
  Entry --> Game
  Entry --> State
  Entry --> Timer
  Entry --> Chat
  Entry --> Bot
  Entry --> Obs
  Entry --> Events
}

node "Upstash\n(plan Free — 100MB, 10K cmd/día)" as UpstashNode {
  database "Redis\n(estado + Pub/Sub interno\nen el mismo proceso)" as Redis
}

Jugador -down-> Client : HTTPS
Client -down-> RenderWeb : WSS (Socket.io)\npuerto 443

Auth <-down-> Redis : jugador:{googleId}
Rooms <-down-> Redis : sala:{codigo}
Game <-down-> Redis : sala:{codigo}, locks, energía
State <-down-> Redis : getRoom / saveRoom
Timer <-down-> Redis : leader election (SETNX)\n"trivial con 1 sola instancia"
Chat <-down-> Redis : historial de mensajes
Obs -down-> Redis : KPIs (stats:kpi:{fecha})

note bottom of RenderWeb
  Todos los módulos comparten el mismo proceso Node.js.
  No hay Gateway, Broker ni servicios separados todavía —
  esa es la **arquitectura destino** (ver 06-despliegue-objetivo.puml).
  19 archivos JavaScript, ~729 LOC (Proyecto.md §1).
end note

note bottom of UpstashNode
  Costo total del MVP: **$0**.
  Si se necesita replicar (2+ instancias), Render Starter
  cuesta ~$7/mes por servicio adicional (Proyecto.md §4.2).
end note

@enduml
