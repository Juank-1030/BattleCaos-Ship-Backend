@startuml 10-secuencia-acceso-identificacion

title Diagrama de Secuencia — Acceso, Identificación y Creación/Unión a Sala
header Inception.md DOCH02/DOCF101: identificación → conexión → creación/unión a sala

!theme plain
skinparam defaultFontName Consolas
skinparam wrapWidth 220
skinparam participant {
  BackgroundColor LightGray
  BorderColor Black
}
skinparam database {
  BackgroundColor LightBlue
  BorderColor Blue
}
skinparam sequenceMessageAlign center

actor "Visitante" as V
participant "Cliente\n(React)" as CL
participant "Gateway" as GW
participant "Auth\nService" as AU
participant "Proveedor de\nidentidad externo" as IdP
participant "Room\nService" as RM
database "Redis" as RS

== Identificación ==
V -> CL : clic en "Entrar con Google"
CL -> AU : GET /auth/google
AU -> IdP : redirige a autenticación externa
IdP --> V : pantalla de consentimiento
V -> IdP : aprueba
IdP -> AU : GET /auth/google/callback?code=...
AU -> IdP : intercambia code por perfil
IdP --> AU : { sub, name, picture }
AU -> AU : createToken(payload)\n(credencial de sesión firmada,\nvigencia 24h)
AU --> CL : redirige a /lobby?token=JWT
CL -> CL : guarda el token SOLO en memoria\n(nunca en localStorage)

== Conexión en tiempo real ==
CL -> GW : connect() { auth: { token } }
GW -> AU : verify(token) "(middleware io.use)"
alt Token inválido o ausente
  AU --> GW : error
  GW --> CL : disconnect('auth:invalid_token')
else Token válido
  AU --> GW : { playerId, name, picture }
  GW -> GW : socket.playerId = playerId
  GW --> CL : connection established
end

== Creación de sala ==
CL -> GW : room:create { modo: "1v1" }
GW -> RM : forward(room:create)
RM -> RM : generateRoomCode()\n"(código único de 6 dígitos)"
RM -> RS : SET sala:{codigo}\n{ modo, fase: LOBBY, jugadores: [] }
RM -> GW : ack({ ok: true, codigo })
GW -> CL : código de sala generado

== Unión a sala ==
actor "Otro usuario" as V2
participant "Cliente 2" as CL2
V2 -> CL2 : ingresa el código
CL2 -> GW : room:join { codigo }
GW -> RM : forward(room:join)
RM -> RS : GET sala:{codigo}
RS --> RM : { modo, fase, jugadores }
RM -> RM : valida existencia y cupo\nsegún modo (1v1=2, 2v2=4)
RM -> RS : SET sala:{codigo}\n(jugador agregado)
RM -> GW : io.to(codigo).emit('sala:jugadores')
GW -> CL : lista de jugadores actualizada
GW -> CL2 : lista de jugadores actualizada
alt Sala llena
  RM -> RM : assignTeams(room)
  RM -> RS : SET sala:{codigo} (equipos asignados)
  RM -> GW : publish(RoomReady)
  GW -> CL : sala:estado { fase: COLOCACION }
  GW -> CL2 : sala:estado { fase: COLOCACION }
end

@enduml
