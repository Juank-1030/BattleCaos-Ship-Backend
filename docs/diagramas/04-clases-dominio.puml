@startuml 04-clases-dominio

title Diagrama de Clases — Modelo de Dominio (Game Service)
header Clases puras, sin imports de infraestructura (Proyecto.md §5.1, §5.2)

!theme plain
skinparam defaultFontName Consolas
skinparam wrapWidth 220
skinparam class {
  BackgroundColor White
  BorderColor Black
  ArrowColor Black
}
skinparam note {
  BackgroundColor LightYellow
  BorderColor Orange
}

class GameEngine {
  +processShot(room, playerId, target): ShotResult
  +placeShip(room, playerId, shipId, positions): PlacementResult
  +usePower(room, playerId, powerType, target): PowerResult
  +startSalvo(room): void
  +endSalvo(room): SalvoResult
  +pauseTurn(room, playerId): void
  +resumeTurn(room, playerId): void
  +checkGameOver(room): GameOverResult
  +createSession(roomConfig): GameSession
}

class Board {
  -grid: Cell[][]
  +createBoard(size): Board
  +placeShip(shipId, positions): void
  +shoot(x, y): ShootResult
  +markShot(x, y): void
  +isValidCoordinate(x, y): boolean
  +getCell(x, y): Cell
}

class Cell {
  +x: int
  +y: int
  +hasShip: boolean
  +shipId: string
  +isHit: boolean
  +isShielded: boolean
  +shieldTurnsLeft: int
}

class Fleet {
  -ships: Ship[]
  +createFleet(shipsConfig): Fleet
  +placeShip(shipId, positions): void
  +checkSink(shipId): boolean
  +allSunk(): boolean
}

class Ship {
  +id: string
  +name: string
  +length: int
  +positions: Position[]
  +hits: int
  +isSunk(): boolean
}

class Salvo {
  +tryShoot(room, playerId, x, y, lockPort): SalvoShotResult
  +collectResults(room): SalvoResult[]
  +getLocks(room): LockEntry[]
  +validateCadence(playerId, lastShotAt, now): boolean
}

class Powers {
  +validate(powerType, room, playerId): boolean
  +apply(powerType, room, target): PowerEffect
  +AREA_BOMB: PowerConfig
  +SONAR: PowerConfig
  +SHIELD: PowerConfig
  +STORM: PowerConfig
}

class Energy {
  +grantEnergy(room, equipo, amount): void
  +spendEnergy(room, equipo, amount): boolean
  +refundEnergy(room, equipo, amount): void
  +getEnergy(room, equipo): int
}

class Countermeasure {
  +openWindow(room, powerType, attackerId, targetPlayerId): Window
  +activate(room, targetPlayerId): CountermeasureResult
  +resolve(room, activated): void
  +isInWindow(room): boolean
}

class Player {
  +id: string
  +name: string
  +picture: string
  +socketId: string
  +equipo: string
  +conectado: boolean
  +desconectadoDesde: timestamp
}

class GameSession {
  +codigo: string
  +modo: string
  +fase: FaseEnum
  +jugadores: Player[]
  +equipos: Map<string, Team>
  +tableros: Map<string, Board>
  +turno: TurnInfo
  +energia: Map<string, int>
  +historial: Event[]
  +timeline: TimelineEntry[]
}

class Team {
  +nombre: string
  +jugadores: string[]
  +energia: int
}

enum FaseEnum {
  LOBBY
  COLOCACION
  TURNOS
  SALVA
  FIN
}

class TurnInfo {
  +jugadorActual: string
  +equipoActual: string
  +rondaActual: int
}

' --- Relaciones de composición/dominio ---
GameEngine "1" --> "1" GameSession : opera sobre
GameEngine --> Board : usa
GameEngine --> Fleet : usa
GameEngine --> Powers : usa
GameEngine --> Energy : usa
GameEngine --> Salvo : usa "(fase SALVA)"
GameEngine --> Countermeasure : usa "(poderes ofensivos)"

Board "1" *-- "*" Cell : contiene
Fleet "1" *-- "*" Ship : contiene
GameSession "1" *-- "*" Player : jugadores
GameSession "1" *-- "*" Team : equipos
GameSession "1" *-- "*" Board : tableros
GameSession "1" *-- "1" TurnInfo : turno
GameSession "1" --> "1" FaseEnum : fase
Team "1" o-- "*" Player : jugadores

' --- Puertos que usa el dominio (interfaces, no implementaciones) ---
interface GameStatePort {
  +getRoom(codigo): GameSession
  +saveRoom(room): void
  +deleteRoom(codigo): void
}

interface LockPort {
  +acquireLock(key, ttl): boolean
  +releaseLock(key): void
}

interface TimerPort {
  +startTimer(codigo, tipo, onEnd): void
  +stopTimer(codigo): void
  +pauseTimer(codigo): void
}

interface EventPort {
  +publish(eventName, payload): void
}

interface BroadcastPort {
  +broadcastState(room): void
}

GameEngine ..> GameStatePort : «uses»
Salvo ..> LockPort : «uses»
GameEngine ..> TimerPort : «uses»
GameEngine ..> EventPort : «uses»
GameEngine ..> BroadcastPort : «uses»

note right of Player::conectado
  Atributo agregado por la corrección de
  Inception.md DOMH05/DOMF402: distingue
  "perdió la conexión" de "abandonó la partida".
  Lo gestiona Room Service; Game Service solo
  lo consulta para decidir si pausar el turno.
end note

note right of Salvo
  **Núcleo de concurrencia del proyecto**
  (Proyecto.md §9.3, Inception.md DOMF1002).
  `tryShoot` es la única función que toca el
  LockPort: garantiza que, aunque lleguen varios
  disparos casi al mismo tiempo a la misma celda,
  solo el primero obtenga el resultado.
end note

@enduml
