@startuml 01-componentes-general

title Diagrama de Componentes — Vista General del Sistema
header Arquitectura Híbrida: Hexagonal + Event-Driven + Microservicios — basado en Proyecto.md §2 y §3

!theme plain
skinparam defaultFontName Consolas
skinparam wrapWidth 220
skinparam component {
  BackgroundColor LightGray
  BorderColor Black
  ArrowColor Black
}
skinparam database {
  BackgroundColor LightBlue
  BorderColor Blue
}
skinparam package {
  BackgroundColor White
  BorderColor Gray
}
skinparam actor {
  BorderColor Red
}
skinparam note {
  BackgroundColor LightYellow
  BorderColor Orange
}

actor "Usuario\n(cliente web React)" as Cliente

package "Punto único de entrada" {
  component "[[#gateway Gateway]]\n· Auth middleware (JWT)\n· Rate limiting por IP/token\n· Enruta eventos al servicio correcto\n· Reenvía broadcasts a los clientes\n· Health check GET /health" as Gateway
}

package "Servicios de dominio (uno por bounded context)" {
  component "Auth Service\nVerifica/emite JWT\nSolo HTTP, sin estado" as Auth
  component "Room Service\nCiclo de vida de salas\nDesconexión ≠ abandono" as Room
  component "Game Service\n(núcleo hexagonal)\nFases, disparos, poderes,\nenergía, salva simultánea" as Game
  component "Timer Service\nLeader election (SETNX)\nTimers reales + ticks" as Timer
  component "Chat Service\nMensajería equipo/general\nNo crítico" as Chat
  component "Bot Service\nIA del oponente automático\nNo crítico" as Bot
  component "Observability Service\nKPIs, logs, audit trail\nSolo consume, nunca publica" as Obs
}

package "Infraestructura compartida" {
  component "Message Broker\n(Redis Pub/Sub)\nCada evento se publica una\nvez y lo consumen N suscriptores" as Broker
  database "Redis State\n(Upstash)\nsala:{codigo}\nenergia, locks, KPIs,\nchat history" as Redis
}

' --- Conexión del cliente ---
Cliente -down-> Gateway : WSS (Socket.io)\n"todas las interacciones de juego"

' --- Gateway hacia servicios (síncrono / reenvío) ---
Gateway -right-> Auth : HTTP\nverify(token)\n(síncrono, cacheable)
Gateway -down-> Room : reenvía\nroom:create, room:join
Gateway -down-> Game : reenvía\ndisparo:realizar, salva:disparo,\npoder:usar, colocacion:set,\ncontramedida:activar
Gateway -down-> Chat : reenvía\nchat:mensaje

' --- Servicios hacia el broker ---
Room -right-> Broker : publish(RoomReady,\nPlayerDisconnectedFromRoom,\nPlayerReconnected, RoomDestroyed,\nPlayerRoomJoined)
Game -right-> Broker : publish(GameStarted, ShotFired,\nPhaseChanged, PowerUsed,\nPowerCompensated, GameEnded,\nShipsPlaced, ShipSunk)
Timer -right-> Broker : publish(TimerEnd, TimerTick)
Chat -right-> Broker : publish(ChatMessage)
Bot -right-> Broker : publish(BotDecision)
Gateway -right-> Broker : publish(PlayerDisconnected)\n"evento crudo: solo dice que\nel socket se cayó"

' --- Broker hacia servicios (consumo asíncrono) ---
Broker -left-> Game : consume(RoomReady, TimerEnd,\nPlayerDisconnectedFromRoom,\nPlayerReconnected, BotDecision)
Broker -left-> Timer : consume(PhaseChanged, RoomReady)
Broker -left-> Room : consume(GameEnded, PlayerDisconnected)
Broker -left-> Chat : consume(PlayerRoomJoined)
Broker -left-> Bot : consume(ShotFired, PhaseChanged)
Broker -left-> Obs : consume(*)\n"todos los eventos, sin excepción"
Broker -up-> Gateway : consume(PhaseChanged, TimerTick)\n"para reenviar al cliente"

' --- Acceso a estado compartido ---
Game <-down-> Redis : getRoom / saveRoom\nlocks atómicos (SETNX)\nINCRBY/DECRBY energía
Room <-down-> Redis : CRUD de sala\n(estado conectado:true/false\npor jugador)
Chat <-down-> Redis : historial (LTRIM 100 msgs)
Obs -down-> Redis : write KPIs (stats:kpi:{fecha})
Timer <-down-> Redis : leader election\n(SET NX EX + heartbeat)

note bottom of Redis
  **SPOF reconocido.** Toda la verdad del sistema vive aquí.
  Sin Redis no hay estado, locks, energía ni Pub/Sub.
  Mitigación MVP: backups Upstash. Futuro: Sentinel/Cluster.
  (Proyecto.md §8.3, §9.1)
end note

note bottom of Gateway
  **SPOF reconocido.** Único punto de entrada público.
  Mitigación: 2+ réplicas con Render Load Balancer o Cloudflare.
end note

note as Tension
  **Tensión filosófica deliberada (Proyecto.md §2):**
  el cómputo se descentraliza en 7 servicios, pero el estado
  y el tráfico siguen centralizados en Redis y en el Gateway.
  Aceptable para un proyecto académico con <100 jugadores
  simultáneos; en producción se mitigaría con HA real.
end note

@enduml
